# This .gitignore file should be placed at the root of your Unity project
# It will ignore files and directories that do not need to be committed to the repository.

# Ignore the .vs folder (Visual Studio settings)
.vs/

# Ignore the .idea folder (JetBrains Rider or IntelliJ IDEA settings)
.idea/

# Ignore the Library folder (contains temporary files Unity generates)
Library/

# Ignore the Temp folder (generated during builds)
Temp/

# Ignore the Build folder (generated when building the project)
Build/

# Ignore the obj folder (used by Visual Studio for object files)
obj/

# Ignore user-specific files
UserSettings/

# Ignore system files like .DS_Store (macOS) or Thumbs.db (Windows)
.DS_Store
Thumbs.db

# Ignore log files
*.log

# Ignore Unity's auto-generated asset files
*.userprefs

# Ignore Unity's exported asset bundles (for different platforms)
AssetBundles/

# Ignore Unity crash dumps
*.stackdump

# Ignore backup and config files
*.bak
*.swp
*.suo

# Ignore Visual Studio Code settings (if using VS Code)
.vscode/

# Ignore Unity's package manager cache
.Packages/

# Ignore Unity cache folders (for Windows and macOS)
# Windows
UnityCache/
# macOS
*.swp

# Ignore the Android/iOS generated files and directories (when building for mobile)
# Android
*.apk
# iOS
*.xcodeproj